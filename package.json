{
  "name": "tabula",
  "productName": "tabula",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "build:renderer": "esbuild src/renderer/main.jsx --bundle --outfile=src/renderer/app.js --format=iife --target=chrome130 --jsx=automatic --loader:.jsx=jsx --define:process.env.NODE_ENV=\\\"production\\\" --external:electron",
    "watch:renderer": "esbuild src/renderer/main.jsx --bundle --outfile=src/renderer/app.js --format=iife --target=chrome130 --jsx=automatic --loader:.jsx=jsx --define:process.env.NODE_ENV=\\\"development\\\" --external:electron --watch",
    "start": "npm run build:renderer && electron-forge start",
    "dev": "concurrently \"npm run watch:renderer\" \"electron-forge start\"",
    "package": "npm run build:renderer && electron-forge package",
    "make": "npm run build:renderer && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "archishsoni",
    "email": "127274757+archishsoni@users.noreply.github.com"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "electron": "41.2.0",
    "esbuild": "^0.28.0"
  }
}
