# Anthropic API key — when LITELLM_BASE_URL is set, this should be the
# LiteLLM master key (not the real Anthropic key). The real Anthropic key
# lives inside the LiteLLM proxy's env, not here.
ANTHROPIC_API_KEY=sk-tabula-dev-local

# Route SDK calls through the local LiteLLM proxy.
# Comment this out to hit Anthropic directly (no audit, no extra masking —
# local visual redaction still runs).
LITELLM_BASE_URL=http://localhost:4000

# ─── Plaid ───────────────────────────────────────────────────────────
# Sandbox keys come from https://dashboard.plaid.com/team/keys
# When PLAID_CLIENT_ID is empty, the in-app "Connect bank" surface is
# disabled — the rest of the app keeps working.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Comma-separated. Default products = transactions, identity, liabilities.
# Add 'income_verification' once enabled on the dashboard.
PLAID_PRODUCTS=transactions,identity,liabilities
PLAID_COUNTRY_CODES=US
# Optional Webhook URL (e.g. ngrok during dev) for transaction sync events.
PLAID_WEBHOOK=
