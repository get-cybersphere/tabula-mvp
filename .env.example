# Anthropic API key — when LITELLM_BASE_URL is set, this should be the
# LiteLLM master key (not the real Anthropic key). The real Anthropic key
# lives inside the LiteLLM proxy's env, not here.
ANTHROPIC_API_KEY=sk-tabula-dev-local

# Route SDK calls through the local LiteLLM proxy.
# Comment this out to hit Anthropic directly (no audit, no extra masking —
# local visual redaction still runs).
LITELLM_BASE_URL=http://localhost:4000
